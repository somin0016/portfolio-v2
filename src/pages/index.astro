---
/* component imports */
import Layout from "../layouts/Layout.astro";
import ExperienceList from "../components/Experience/ExperienceList.astro";
import Section from "../components/Elements/Section/Section.astro";
import FeaturedProjectList from "../components/FeaturedProjects/FeaturedProjectList.astro";
import EmailIcon from "../components/Icons/EmailIcon.astro";
import WhatsAppIcon from "../components/Icons/WhatsAppIcon.astro";
import LinkedInIcon from "../components/Icons/LinkedInIcon.astro";
import CVIcon from "../components/Icons/CVIcon.astro";

/* init */
const experience = [
  {
    period: "2024 — Present",
    role: "Research Software Development Engineer",
    org: "Singapore-MIT Alliance for Research and Technology (SMART)",
    description:
      "Building software platforms and tools supporting research in human-AI collaboration.",
  },
  {
    period: "2023 — 2024",
    role: "Software Engineer Intern",
    org: "Saltmine",
    description:
      "Worked on full-stack development and backend architecture improvements within a microservice environment.",
  },
  {
    period: "2023 — 2024",
    role: "Graduate Diploma in Systems Analysis",
    org: "National University of Singapore (NUS-ISS)",
  },
  {
    period: "2021 — 2022",
    role: "Junior Software Developer",
    org: "Seattle Consulting Myanmar",
    description:
      "Developed enterprise web applications and internal tools using Vue.js and Ruby on Rails.",
  },
  {
    period: "2020",
    role: "BSc (Hons) Computing",
    org: "University of Gloucestershire",
  },
];

const featuredProjects = [
  {
    name: "Ontology of Collective Intelligence",
    description:
      "Large-scale collaborative ontology platform supporting research in human-AI collaboration, featuring real-time editing, graph visualizations, and scalable knowledge structures.",
    skills: [
      "Next.js",
      "TypeScript",
      "Firebase",
      "Firestore",
      "Yjs",
      "React",
      "D3.js",
      "LLMs",
    ],
    slug: "ontology",
    links: [
      {
        name: "Website",
        url: "https://ontology.mit.edu",
      },
      {
        name: "GitHub",
        url: "https://github.com/MIT-Center-for-Collective-Intelligence/1Ontology",
      },
    ],
  },
  {
    name: "Activity Logging System",
    description:
      "Migration and redesign of a high-traffic activity logging system from Elasticsearch to PostgreSQL with improved scalability and maintainability.",
    skills: [
      "PostgreSQL",
      "NestJS",
      "ExpressJS",
      "Elasticsearch",
      "Database Design",
      "Data Migration",
    ],
    slug: "context",
  },
  {
    name: "CodeMap",
    description:
      "Research-driven platform for understanding unfamiliar codebases through interactive visualizations, hierarchical exploration, and human-AI collaboration.",
    skills: [
      "TypeScript",
      "React",
      "LLMs",
      "OpenAI",
      "Data Visualization",
      "Research",
    ],
    slug: "codemap",
    links: [
      {
        name: "Website",
        url: "https://gaojie058.github.io/code-map/",
      },
    ],
  },
];
---

<Layout>
  <!-- INTRO STARTS -->
  <Section>
    <div class="grid sm:grid-cols-3 gap-4 pt-8 sm:pt-4 items-center">
      <div class="sm:col-span-2 flex flex-col order-2 sm:order-1">
        <div class="mb-8 text-fg">
          <p class="">Hello,</p>
          <h1 class="text-3xl font-bold tracking-tight">
            I'm Soe Min Thant! 👋
          </h1>
        </div>
        <p class="text-base font-normal text-fg">
          Software Engineer at <a
            href="https://m3s.mit.edu/"
            target="_blank"
            rel="noreferrer"
            class="inline-link">SMART M3S</a
          >, building software and tools for human-AI collaboration.
        </p>
        <div class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm">
          <a
            href="mailto:tsoominn@gmail.com"
            class="inline-flex items-center gap-1.5 text-fg hover:text-accent"
          >
            <EmailIcon />
            Email
          </a>
          <a
            href="https://wa.me/84511155"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 text-fg hover:text-accent"
          >
            <WhatsAppIcon />
            WhatsApp
          </a>
          <a
            href="https://www.linkedin.com/in/soeminthant/"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-1.5 text-fg hover:text-accent"
          >
            <LinkedInIcon />
            LinkedIn
          </a>
          <a
            href="/SoeMinThant.pdf"
            download
            class="inline-flex items-center gap-1.5 text-fg hover:text-accent"
          >
            <CVIcon />
            CV
          </a>
        </div>
      </div>
      <div class="sm:col-span-1 order-1 sm:order-2 sm:flex sm:justify-end">
        <img
          class="w-40 sm:w-52 aspect-square rounded-md object-cover"
          src="/smt_pfp.jpeg"
          alt="Soe Min Thant"
        />
      </div>
    </div>
  </Section>
  <!-- INTRO ENDS -->

  <!-- ABOUT STARTS -->
  <Section title="About" circle="#0D99FF">
    <div class="grid grid-cols-3 gap-2">
      <div class="col-span-3">
        <p class="mb-3">
          I currently work as a Research Software Development Engineer at
          Singapore-MIT Alliance for Research and Technology (SMART), where I
          build platforms and tools supporting research in human-AI
          collaboration. My work involves designing and improving systems that
          support knowledge organization, collaboration, and AI-assisted
          workflows.
        </p>
        <p class="mb-3">
          Beyond building software, I have always been interested in
          understanding how things work beneath the surface. I enjoy exploring
          how systems are designed, how they evolve as they grow, and the
          trade-offs involved in building and maintaining them.
        </p>
      </div>
    </div>
  </Section>
  <!-- ABOUT ENDS -->

  <!-- PROJECTS STARTS -->
  <Section title="Featured Projects" circle="#FFCD29">
    <FeaturedProjectList projects={featuredProjects} />
  </Section>
  <!-- PROJECTS ENDS -->

  <!-- EXPERIENCE STARTS -->
  <Section title="Experience" circle="#F24822">
    <ExperienceList entries={experience} />
  </Section>
  <!-- EXPERIENCE ENDS -->
</Layout>
