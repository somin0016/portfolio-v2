---
/* component imports */
import Layout from "../layouts/Layout.astro";
// import BlogList from "../components/Blog/BlogList";

/* constants */
import { WORDPRESS_BLOG_URL } from "../constants";
---

<Layout>
  <div class="pt-8">
    <h1 class="sm:hidden text-4xl font-bold mb-8">Blog</h1>
    <p>I do some blogging whenever I feel bored or find interesting topics.</p>
    <!-- Blog List -->
    <div class="mt-16 sm:mt-20">
      <div class="flex justify-between items-center mt-10 pb-2">
        <h2 class="text-2xl font-bold">Recent</h2>
        <a
          href={WORDPRESS_BLOG_URL}
          target="_blank"
          class="text-sm hover:underline hover:cursor-pointer">View all</a
        >
      </div>
      <!-- Blog list temporarily disabled -->
      <!-- <BlogList client:load /> -->
      <div
        role="status"
        class="mt-6 flex flex-col items-center gap-3 py-10 text-center text-fg/70"
      >
        <span class="text-4xl" role="img" aria-label="face with bags under eyes"
          >🫩</span
        >
        <p class="max-w-sm">
          Sorry, the blog is taking a little break right now.
        </p>
      </div>
    </div>
  </div>
</Layout>
