---
import { getCollection, type CollectionEntry } from "astro:content";
import ProjectPost from "../../layouts/ProjectPost.astro";

export async function getStaticPaths() {
  const projects = await getCollection("project");
  const sorted = projects.sort((a, b) => {
    if (b.data.year !== a.data.year) return b.data.year - a.data.year;
    // within the same year, order by `index` (ascending, starting at 0);
    // entries without an index fall to the end
    return (a.data.index ?? Infinity) - (b.data.index ?? Infinity);
  });
  return sorted.map((project, index) => ({
    params: { slug: project.slug },
    props: {
      project,
      prev: sorted[index - 1] ?? null,
      next: sorted[index + 1] ?? null,
    },
  }));
}

interface Props {
  project: CollectionEntry<"project">;
  prev: CollectionEntry<"project"> | null;
  next: CollectionEntry<"project"> | null;
}

const { project, prev, next } = Astro.props;
const { Content } = await project.render();
---

<ProjectPost {...project.data} prev={prev} next={next}>
  <Content />
</ProjectPost>
