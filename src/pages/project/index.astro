---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const projects = (await getCollection("project")).sort((a, b) => {
  if (b.data.year !== a.data.year) return b.data.year - a.data.year;
  // within the same year, order by `index` (ascending, starting at 0);
  // entries without an index fall to the end
  return (a.data.index ?? Infinity) - (b.data.index ?? Infinity);
});

const groupedByYear = projects.reduce(
  (acc, project) => {
    const year = project.data.year;
    if (!acc[year]) acc[year] = [];
    acc[year].push(project);
    return acc;
  },
  {} as Record<number, typeof projects>,
);

const years = Object.keys(groupedByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<Layout>
  <div class="pt-8">
    <h1 class="sm:hidden text-4xl font-bold mb-8">Projects</h1>
    <div class="space-y-10">
      {
        years.map((year) => (
          <section>
            <h2 class="text-sm font-medium text-muted tabular-nums pb-3 mb-2 border-b border-border">
              {year}
            </h2>
            <ul class="divide-y divide-border">
              {groupedByYear[year].map((project) => (
                <li>
                  <a
                    href={`/project/${project.slug}/`}
                    class="group flex items-start justify-between gap-4 py-4 text-fg hover:text-accent transition-colors"
                  >
                    <div class="flex-1 min-w-0">
                      <div class="inline-flex items-center gap-2 text-base font-medium">
                        <span class="w-1.5 h-1.5 rounded-full bg-current shrink-0" />
                        {project.data.title}
                      </div>
                      <p class="text-sm text-muted mt-0.5 pl-3.5">
                        {project.data.description}
                      </p>
                    </div>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke-width="2"
                      stroke="currentColor"
                      class="w-3 h-3 shrink-0 mt-2 transition-transform duration-200 group-hover:translate-x-0.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"
                      />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</Layout>
