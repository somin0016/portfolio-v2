---
interface Entry {
  period: string;
  role: string;
  org: string;
  description?: string;
}

interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;
---

<ul class="divide-y divide-border">
  {
    entries.map((entry) => (
      <li class="py-6 sm:grid sm:grid-cols-[9rem_1fr] sm:gap-6">
        <div class="text-sm text-muted tabular-nums shrink-0 sm:pt-0.5">
          {entry.period}
        </div>
        <div class="mt-1.5 sm:mt-0">
          <h3 class="text-base font-medium text-fg">{entry.role}</h3>
          <p class="text-sm text-muted">{entry.org}</p>
          {entry.description && (
            <p class="text-sm text-muted mt-2 leading-relaxed">
              {entry.description}
            </p>
          )}
        </div>
      </li>
    ))
  }
</ul>
