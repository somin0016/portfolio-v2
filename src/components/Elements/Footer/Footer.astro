---
import Container from "../Container/Container.astro";

const lastUpdated = new Date().toLocaleDateString("en-US", {
  month: "long",
  year: "numeric",
});

const stack = [
  { name: "Astro", url: "https://astro.build/" },
  { name: "React", url: "https://react.dev/" },
  { name: "Tailwind CSS", url: "https://tailwindcss.com/" },
];
---

<footer class="mt-20 sm:mt-40 pb-8">
  <Container>
    <div
      class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 text-xs text-muted"
    >
      <p class="flex flex-wrap items-center gap-x-1.5 gap-y-1">
        <span>Built using</span>
        {
          stack.map((tech, i) => (
            <>
              <a
                href={tech.url}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-0.5 hover:text-fg transition-colors underline-offset-4 hover:underline"
              >
                {tech.name}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="w-2.5 h-2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M7 17 17 7M7 7h10v10"
                  />
                </svg>
              </a>
              {i < stack.length - 1 && <span>,</span>}
            </>
          ))
        }
      </p>
      <p>Last updated {lastUpdated}</p>
    </div>
  </Container>
</footer>
