---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/project/", label: "Projects" },
  { href: "/blog/", label: "Blog" },
  { href: "/now/", label: "Now" },
];

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  const base = href.replace(/\/$/, "");
  return pathname === base || pathname.startsWith(base + "/");
};
---

<div class="fixed top-3 right-4 z-50 sm:hidden">
  <button
    id="mobile-toggle"
    type="button"
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="mobile-panel"
    class="mobile-toggle relative w-12 h-12 rounded-full flex items-center justify-center"
  >
    <span class="line line-1"></span>
    <span class="line line-2"></span>
  </button>

  <div
    id="mobile-panel"
    class="mobile-panel absolute top-14 right-0 min-w-[210px] p-2 rounded-2xl"
    aria-hidden="true"
  >
    <ul class="flex flex-col">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "block py-2.5 px-3 rounded-lg text-base transition-colors",
                isActive(link.href)
                  ? "text-fg font-medium"
                  : "text-muted hover:text-accent",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <button
          type="button"
          class="js-theme-toggle block w-full text-left py-2.5 px-3 rounded-lg text-base text-muted hover:text-accent transition-colors"
        >
          <span class="js-theme-label">Dark mode</span>
        </button>
      </li>
    </ul>
  </div>
</div>

<style>
  .mobile-toggle {
    background-color: rgba(250, 250, 247, 0.72);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.06),
      0 6px 24px -6px rgba(20, 14, 4, 0.12),
      0 2px 8px -3px rgba(20, 14, 4, 0.06);
    color: var(--color-fg);
    transition: transform 0.2s ease;
    z-index: 2;
  }

  .mobile-toggle:hover {
    transform: scale(1.05);
  }

  .mobile-toggle:active {
    transform: scale(0.95);
  }

  :global(html.dark) .mobile-toggle {
    background-color: rgba(28, 26, 23, 0.68);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 8px 32px -6px rgba(0, 0, 0, 0.55),
      0 2px 10px -3px rgba(0, 0, 0, 0.35);
  }

  /* 2-line hamburger that morphs into X */
  .line {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 2.5px;
    background: currentColor;
    border-radius: 2px;
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .line-1 {
    transform: translate(-50%, calc(-50% - 5px));
  }
  .line-2 {
    transform: translate(-50%, calc(-50% + 5px));
  }
  .mobile-toggle.open .line-1 {
    transform: translate(-50%, -50%) rotate(45deg);
  }
  .mobile-toggle.open .line-2 {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  /* Panel */
  .mobile-panel {
    background-color: rgba(250, 250, 247, 0.72);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.06),
      0 8px 32px -8px rgba(20, 14, 4, 0.18),
      0 4px 12px -4px rgba(20, 14, 4, 0.08);
    opacity: 0;
    pointer-events: none;
    transform: scale(0.9) translateY(-8px);
    transform-origin: top right;
    transition:
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(html.dark) .mobile-panel {
    background-color: rgba(28, 26, 23, 0.72);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 10px 36px -8px rgba(0, 0, 0, 0.6),
      0 4px 14px -4px rgba(0, 0, 0, 0.4);
  }

  .mobile-panel.open {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1) translateY(0);
  }
</style>

<script is:inline>
  (() => {
    const toggle = document.getElementById("mobile-toggle");
    const panel = document.getElementById("mobile-panel");
    if (!toggle || !panel) return;

    const setOpen = (open) => {
      toggle.classList.toggle("open", open);
      panel.classList.toggle("open", open);
      toggle.setAttribute("aria-expanded", String(open));
      panel.setAttribute("aria-hidden", String(!open));
    };

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      setOpen(!toggle.classList.contains("open"));
    });

    document.addEventListener("click", (e) => {
      if (!toggle.contains(e.target) && !panel.contains(e.target)) {
        setOpen(false);
      }
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
  })();
</script>
