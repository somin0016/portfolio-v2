---
import Navigation from "./Navigation.astro";
import Container from "../Container/Container.astro";
import MobileNav from "./MobileNav.astro";
---

<header class="hidden sm:block sticky top-3 pb-8 z-50">
  <Container>
    <nav id="site-nav" class="my-6 transition-all duration-300 ease-out">
      <Navigation />
    </nav>
  </Container>
</header>

<MobileNav />

<style>
  #site-nav.scrolled {
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
    padding: 0.75rem 1.25rem;
    border-radius: 9999px;
    background-color: rgba(250, 250, 247, 0.72);
    backdrop-filter: blur(14px) saturate(180%);
    -webkit-backdrop-filter: blur(14px) saturate(180%);
    box-shadow:
      inset 0 0 0 1px rgba(0, 0, 0, 0.06),
      0 6px 24px -6px rgba(20, 14, 4, 0.12),
      0 2px 8px -3px rgba(20, 14, 4, 0.06);
  }

  :global(html.dark) #site-nav.scrolled {
    background-color: rgba(28, 26, 23, 0.68);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      0 8px 32px -6px rgba(0, 0, 0, 0.55),
      0 2px 10px -3px rgba(0, 0, 0, 0.35);
  }
</style>

<script is:inline>
  const onScroll = () => {
    const el = document.getElementById("site-nav");
    if (!el) return;
    el.classList.toggle("scrolled", window.scrollY > 80);
  };
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
