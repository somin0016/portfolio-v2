---
import type { CollectionEntry } from "astro:content";
import Layout from "./Layout.astro";

interface ProjectLink {
  name: string;
  url: string;
}

interface Props {
  title: string;
  description: string;
  year: number;
  index?: number;
  background: string;
  heroImage?: string;
  skills?: string[];
  links?: ProjectLink[];
  prev?: CollectionEntry<"project"> | null;
  next?: CollectionEntry<"project"> | null;
}

const { title, description, year, skills, links, prev, next } = Astro.props;
---

<Layout>
  <article class="pt-8">
    <!-- Back link -->
    <a
      href="/project/"
      class="inline-flex items-center gap-1.5 text-sm text-muted hover:text-fg transition-colors group"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="w-3.5 h-3.5 transition-transform duration-200 group-hover:-translate-x-0.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6.75 15.75 3 12m0 0 3.75-3.75M3 12h18"></path>
      </svg>
      All projects
    </a>

    <!-- Header -->
    <header class="mt-10 pb-8 border-b border-border">
      <p class="text-sm text-muted tabular-nums mb-2">{year}</p>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
        {title}
      </h1>
      <p class="text-lg text-muted leading-relaxed">{description}</p>
      {
        skills && skills.length > 0 && (
          <p class="mt-4 text-xs text-muted leading-relaxed">
            {skills.join(" · ")}
          </p>
        )
      }
      {
        links && links.length > 0 && (
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
            {links.map((link) => (
              <a
                href={link.url}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-1 text-fg hover:text-accent transition-colors"
              >
                {link.name}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="w-3 h-3"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M7 17 17 7M7 7h10v10"
                  />
                </svg>
              </a>
            ))}
          </div>
        )
      }
    </header>

    <!-- Markdown body -->
    <div class="prose dark:prose-invert mt-10">
      <slot />
    </div>

    <!-- Bottom nav -->
    {
      (prev || next) && (
        <nav class="mt-20 pt-8 border-t border-border grid grid-cols-2 gap-4">
          <div class="min-w-0">
            {prev && (
              <a
                href={`/project/${prev.slug}/`}
                class="group inline-flex flex-col"
              >
                <span class="text-xs uppercase tracking-wider text-muted mb-1">
                  Previous
                </span>
                <span class="inline-flex items-center gap-1.5 text-base font-medium text-fg group-hover:text-accent transition-colors">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="w-3.5 h-3.5 transition-transform duration-200 group-hover:-translate-x-0.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6.75 15.75 3 12m0 0 3.75-3.75M3 12h18"
                    />
                  </svg>
                  {prev.data.title}
                </span>
              </a>
            )}
          </div>
          <div class="min-w-0 text-right">
            {next && (
              <a
                href={`/project/${next.slug}/`}
                class="group inline-flex flex-col items-end"
              >
                <span class="text-xs uppercase tracking-wider text-muted mb-1">
                  Next
                </span>
                <span class="inline-flex items-center gap-1.5 text-base font-medium text-fg group-hover:text-accent transition-colors">
                  {next.data.title}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-0.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3"
                    />
                  </svg>
                </span>
              </a>
            )}
          </div>
        </nav>
      )
    }
  </article>
</Layout>
